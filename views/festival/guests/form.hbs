<div class="mx-auto max-w-2xl">
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isEdit}}Edit Guest{{else}}New Guest{{/if}}</h1>

  <form method="POST" action="{{#if isEdit}}/admin/festival/guests/{{guest.id}}{{else}}/admin/festival/editions/{{edition.id}}/guests{{/if}}" class="mt-8 space-y-6">
    {{#unless isEdit}}
    <fieldset>
      <legend class="text-sm/6 font-medium text-gray-900 dark:text-gray-200">Profile</legend>
      <div class="mt-3 space-y-3">
        <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
          <input type="radio" name="profile_mode" value="existing" checked class="size-4 border-gray-300 text-indigo-600" />
          Existing profile
        </label>
        <div class="ml-6">
          <select name="profile_id" id="profile_id"
            class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
            <option value="">Select profile...</option>
            {{#each profiles}}
            <option value="{{this.id}}">{{this.name}}</option>
            {{/each}}
          </select>
        </div>
        <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
          <input type="radio" name="profile_mode" value="new" class="size-4 border-gray-300 text-indigo-600" />
          Create new profile
        </label>
        <div class="ml-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <div>
            <label for="new_profile_name" class="block text-xs font-medium text-gray-500 dark:text-gray-400">Name <span class="text-red-500">*</span> (when new)</label>
            <input type="text" name="new_profile_name" id="new_profile_name"
              class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
          </div>
          <div>
            <label for="new_profile_email" class="block text-xs font-medium text-gray-500 dark:text-gray-400">Email</label>
            <input type="email" name="new_profile_email" id="new_profile_email"
              class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
          </div>
          <div class="sm:col-span-2">
            <label for="new_profile_phone" class="block text-xs font-medium text-gray-500 dark:text-gray-400">Phone</label>
            <input type="text" name="new_profile_phone" id="new_profile_phone"
              class="mt-1 block w-full max-w-md rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
          </div>
        </div>
      </div>
    </fieldset>
    {{/unless}}

    {{#if isEdit}}
    <div>
      <p class="text-sm text-gray-600 dark:text-gray-400">Profile: <span class="font-medium text-gray-900 dark:text-white">{{guest.profile_name}}</span></p>
    </div>
    {{/if}}

    <fieldset>
      <legend class="text-sm/6 font-medium text-gray-900 dark:text-gray-200">Roles</legend>
      <div class="mt-3 space-y-2">
        <div class="flex items-center gap-x-3">
          <input id="role_speaker" name="roles" type="checkbox" value="speaker"
            {{#if (includes guest.roles 'speaker')}}checked{{/if}}
            class="size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="role_speaker" class="text-sm/6 text-gray-900 dark:text-gray-300">Speaker</label>
        </div>
        <div class="flex items-center gap-x-3">
          <input id="role_workshop_org" name="roles" type="checkbox" value="workshop_org"
            {{#if (includes guest.roles 'workshop_org')}}checked{{/if}}
            class="size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="role_workshop_org" class="text-sm/6 text-gray-900 dark:text-gray-300">Workshop Organizer</label>
        </div>
        <div class="flex items-center gap-x-3">
          <input id="role_artist" name="roles" type="checkbox" value="artist"
            {{#if (includes guest.roles 'artist')}}checked{{/if}}
            class="size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="role_artist" class="text-sm/6 text-gray-900 dark:text-gray-300">Artist</label>
        </div>
        <div class="flex items-center gap-x-3">
          <input id="role_other" name="roles" type="checkbox" value="other"
            {{#if (includes guest.roles 'other')}}checked{{/if}}
            class="size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="role_other" class="text-sm/6 text-gray-900 dark:text-gray-300">Other</label>
        </div>
      </div>
    </fieldset>

    <div class="flex items-center gap-x-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">
        {{#if isEdit}}Update{{else}}Create{{/if}}
      </button>
      <a href="{{#if cancelHref}}{{cancelHref}}{{else}}/admin/festival/editions/{{edition.id}}/guests{{/if}}" class="text-sm/6 font-semibold text-gray-900 dark:text-gray-300">Cancel</a>
    </div>
  </form>
</div>

{{#if edition}}
{{> festival_edition_nav edition=edition festivalSubnav='locations'}}
{{/if}}

<div class="mx-auto max-w-2xl">
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isEdit}}Edit Location{{else}}New Location{{/if}}</h1>

  <form method="POST" action="{{#if isEdit}}/admin/festival/locations/{{location.id}}{{else}}/admin/festival/editions/{{edition.id}}/locations{{/if}}" class="mt-8 space-y-6">
    <div>
      <label for="name" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Name <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <input type="text" name="name" id="name" required value="{{location.name}}"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
      </div>
    </div>

    <div>
      <label for="address" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Address</label>
      <div class="mt-2">
        <input type="text" name="address" id="address" value="{{location.address}}"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
      </div>
    </div>

    <div>
      <label for="description" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Description</label>
      <div class="mt-2">
        <textarea name="description" id="description" rows="4"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500">{{location.description}}</textarea>
      </div>
    </div>

    <fieldset>
      <legend class="text-sm/6 font-medium text-gray-900 dark:text-gray-200">Coordinator</legend>
      <div class="mt-3 space-y-3">
        <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
          <input type="radio" name="coordinator_mode" value="existing" checked class="size-4 border-gray-300 text-indigo-600" />
          Existing volunteer
        </label>
        <div class="ml-6">
          <label for="coordinator_id" class="sr-only">Volunteer</label>
          <select name="coordinator_id" id="coordinator_id"
            class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
            <option value="">None</option>
            {{#each volunteers}}
            <option value="{{this.id}}" {{#if (eq this.id ../location.coordinator_id)}}selected{{/if}}>{{this.profile_name}}</option>
            {{/each}}
          </select>
        </div>
        <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
          <input type="radio" name="coordinator_mode" value="new" class="size-4 border-gray-300 text-indigo-600" />
          New profile as volunteer
        </label>
        <div class="ml-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <div>
            <label for="coord_profile_name" class="block text-xs font-medium text-gray-500 dark:text-gray-400">Name <span class="text-red-500">*</span> (when new)</label>
            <input type="text" name="coord_profile_name" id="coord_profile_name"
              class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
          </div>
          <div>
            <label for="coord_profile_email" class="block text-xs font-medium text-gray-500 dark:text-gray-400">Email</label>
            <input type="email" name="coord_profile_email" id="coord_profile_email"
              class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
          </div>
          <div class="sm:col-span-2">
            <label for="coord_profile_phone" class="block text-xs font-medium text-gray-500 dark:text-gray-400">Phone</label>
            <input type="text" name="coord_profile_phone" id="coord_profile_phone"
              class="mt-1 block w-full max-w-md rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
          </div>
        </div>
      </div>
    </fieldset>

    <div class="flex items-center gap-x-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">
        {{#if isEdit}}Update{{else}}Create{{/if}}
      </button>
      <a href="{{#if cancelHref}}{{cancelHref}}{{else}}/admin/festival/editions/{{edition.id}}/locations{{/if}}" class="text-sm/6 font-semibold text-gray-900 dark:text-gray-300">Cancel</a>
    </div>
  </form>
</div>

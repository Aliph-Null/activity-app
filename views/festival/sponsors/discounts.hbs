<div class="mx-auto max-w-4xl">
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-base font-semibold text-gray-900 dark:text-white">Discount Locations: {{sponsor.name}}</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">
        <a href="/admin/festival/editions/{{edition.id}}/sponsors" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400">&larr; Back to sponsors</a>
      </p>
    </div>
  </div>

  <form method="POST" action="/admin/festival/sponsors/{{sponsor.id}}/discounts" class="mt-6 rounded-lg bg-white/5 p-4 dark:bg-white/5">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-5">
      <div>
        <label for="name" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Name</label>
        <input type="text" name="name" id="name" required
          class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
      </div>
      <div>
        <label for="address" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Address</label>
        <input type="text" name="address" id="address"
          class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
      </div>
      <div>
        <label for="discount_percent" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Discount %</label>
        <input type="number" name="discount_percent" id="discount_percent" required min="1" max="100"
          class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
      </div>
      <div>
        <label for="redeem_max" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Max Redeems</label>
        <input type="number" name="redeem_max" id="redeem_max" required min="1"
          class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
      </div>
      <div class="flex items-end">
        <button type="submit" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-500">Add</button>
      </div>
    </div>
  </form>

  <div class="mt-8 flow-root">
    <table class="min-w-full divide-y divide-gray-300 dark:divide-white/10">
      <thead>
        <tr>
          <th class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Name</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Address</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Discount %</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Max Redeems</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Used</th>
          <th class="relative py-3.5 pr-4 pl-3 sm:pr-0"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-white/5">
        {{#each items}}
        <tr>
          <td class="whitespace-nowrap py-4 pr-3 pl-4 text-sm font-medium text-gray-900 dark:text-white sm:pl-0">{{this.name}}</td>
          <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.address}}</td>
          <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.discount_percent}}%</td>
          <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.redeem_max}}</td>
          <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.redeem_count}}</td>
          <td class="relative whitespace-nowrap py-4 pr-4 pl-3 text-right text-sm font-medium sm:pr-0">
            <form method="POST" action="/admin/festival/discounts/{{this.id}}/delete" class="inline">
              <button type="submit" class="text-red-600 hover:text-red-900 dark:text-red-400" onclick="return confirm('Are you sure?')">Delete</button>
            </form>
          </td>
        </tr>
        {{/each}}
        {{#unless items.length}}
        <tr>
          <td colspan="6" class="py-8 text-center text-sm text-gray-500 dark:text-gray-400">No discount locations yet.</td>
        </tr>
        {{/unless}}
      </tbody>
    </table>
  </div>
</div>

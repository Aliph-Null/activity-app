<div class="mx-auto max-w-2xl">
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isProgramEdit}}Edit Program Entry{{else}}New Program Entry{{/if}}</h1>

  <form method="POST" action="{{#if isProgramEdit}}/admin/festival/program/{{program.id}}{{else}}/admin/festival/editions/{{edition.id}}/program{{/if}}" class="mt-8 space-y-6">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div>
        <label for="starts_at" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Starts At <span class="text-red-500">*</span></label>
        <div class="mt-2">
          <input type="datetime-local" name="starts_at" id="starts_at" required value="{{program.starts_at}}"
            class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
        </div>
      </div>
      <div>
        <label for="ends_at" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Ends At</label>
        <div class="mt-2">
          <input type="datetime-local" name="ends_at" id="ends_at" value="{{program.ends_at}}"
            class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
        </div>
      </div>
    </div>

    <div>
      <label for="location_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Location <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <select name="location_id" id="location_id" required
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
          <option value="">Select location...</option>
          {{#each locations}}
          <option value="{{this.id}}" {{#if (eq this.id ../program.location_id)}}selected{{/if}}>{{this.name}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <div>
      <label for="activity_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Activity <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <select name="activity_id" id="activity_id" required
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
          <option value="">Select activity...</option>
          {{#each activities}}
          <option value="{{this.id}}" {{#if (eq this.id ../program.activity_id)}}selected{{/if}}>{{this.title}} ({{this.activity_type}})</option>
          {{/each}}
        </select>
      </div>
    </div>

    <fieldset>
      <legend class="text-sm/6 font-medium text-gray-900 dark:text-gray-200">Presenters</legend>
      <div class="mt-3 space-y-2">
        {{#each guests}}
        <div class="flex items-center gap-x-3">
          <input id="presenter_{{this.id}}" name="presenter_ids" type="checkbox" value="{{this.id}}"
            {{#if (includes ../program.presenter_ids this.id)}}checked{{/if}}
            class="size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="presenter_{{this.id}}" class="text-sm/6 text-gray-900 dark:text-gray-300">{{this.profile_name}}</label>
        </div>
        {{/each}}
        {{#unless guests.length}}
        <p class="text-sm text-gray-500 dark:text-gray-400">No guests available.</p>
        {{/unless}}
      </div>
    </fieldset>

    <div class="flex items-center gap-x-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">{{#if isProgramEdit}}Update{{else}}Create{{/if}}</button>
      <a href="{{#if cancelHref}}{{cancelHref}}{{else}}/admin/festival/editions/{{edition.id}}/program{{/if}}" class="text-sm/6 font-semibold text-gray-900 dark:text-gray-300">Cancel</a>
    </div>
  </form>
</div>

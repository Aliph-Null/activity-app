{{> festival_edition_nav edition=edition festivalSubnav=festivalSubnav }}

<div class="sm:flex sm:items-center">
  <div class="sm:flex-auto">
    <h1 class="text-base font-semibold text-gray-900 dark:text-white">Tickets: {{edition.year}}</h1>
    <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">
      <a href="/admin/festival/editions/{{edition.id}}" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400">&larr; Back to edition overview</a>
    </p>
  </div>
</div>

<form method="POST" action="/admin/festival/editions/{{edition.id}}/tickets" class="mt-6 flex flex-col gap-3 rounded-lg bg-white/5 p-4 sm:flex-row sm:items-end dark:bg-white/5">
  <div>
    <label for="holder_profile_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Holder</label>
    <select name="holder_profile_id" id="holder_profile_id" required
      class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10 sm:w-48">
      <option value="">Select profile...</option>
      {{#each profiles}}
      <option value="{{this.id}}">{{this.name}}</option>
      {{/each}}
    </select>
  </div>
  <div>
    <label for="code" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Code</label>
    <input type="text" name="code" id="code" required
      class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10 sm:w-32" />
  </div>
  <div>
    <label for="guest_count" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Guest Count</label>
    <input type="number" name="guest_count" id="guest_count" min="0" max="5" value="0"
      class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10 sm:w-24" />
  </div>
  <button type="submit" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-500">Add</button>
</form>

<div class="mt-8 flow-root">
  <table class="min-w-full divide-y divide-gray-300 dark:divide-white/10">
    <thead>
      <tr>
        <th class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Code</th>
        <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Holder</th>
        <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Guest Count</th>
        <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Created</th>
        <th class="relative py-3.5 pr-4 pl-3 sm:pr-0"><span class="sr-only">Actions</span></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200 dark:divide-white/5">
      {{#each items}}
      <tr>
        <td class="whitespace-nowrap py-4 pr-3 pl-4 text-sm font-medium text-gray-900 dark:text-white sm:pl-0">{{this.code}}</td>
        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.holder_name}}</td>
        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.guest_count}}</td>
        <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.created_at}}</td>
        <td class="relative whitespace-nowrap py-4 pr-4 pl-3 text-right text-sm font-medium sm:pr-0">
          <form method="POST" action="/admin/festival/tickets/{{this.id}}/delete" class="inline">
            <button type="submit" class="text-red-600 hover:text-red-900 dark:text-red-400" onclick="return confirm('Are you sure?')">Delete</button>
          </form>
        </td>
      </tr>
      {{/each}}
      {{#unless items.length}}
      <tr>
        <td colspan="5" class="py-8 text-center text-sm text-gray-500 dark:text-gray-400">No tickets yet.</td>
      </tr>
      {{/unless}}
    </tbody>
  </table>
</div>

{{> pagination page=page totalPages=totalPages }}

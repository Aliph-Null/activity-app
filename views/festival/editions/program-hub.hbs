{{> festival_edition_nav }}

<div class="mx-auto max-w-6xl">
  {{#unless edition}}
  <p class="text-sm text-red-600 dark:text-red-400">Edition not found.</p>
  <p class="mt-2"><a href="/admin/festival" class="text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">Back to overview</a></p>
  {{else}}
  <div class="sm:flex sm:items-center sm:justify-between">
    <div>
      <h1 class="text-base font-semibold text-gray-900 dark:text-white">Program — {{edition.year}}</h1>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">Schedule by day. Page {{page}} of {{totalPages}} ({{totalRows}} entries).</p>
    </div>
    <p class="mt-4 sm:mt-0">
      <a href="/admin/festival/editions/{{edition.id}}/program/new" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-500">New program entry</a>
    </p>
  </div>

  {{#unless scheduleByDay.length}}
  <div class="mt-8 rounded-lg border border-gray-200 bg-white p-10 text-center dark:border-white/10 dark:bg-gray-950/40">
    <p class="text-sm text-gray-600 dark:text-gray-400">No program entries on this page.</p>
    <a href="/admin/festival/editions/{{edition.id}}/program/new" class="mt-3 inline-block text-sm font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">Add a slot</a>
  </div>
  {{else}}
  <div class="mt-6 space-y-8">
    {{#each scheduleByDay}}
    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm dark:border-white/10 dark:bg-gray-950/40">
      <div class="border-b border-gray-100 bg-gray-50 px-4 py-3 dark:border-white/10 dark:bg-white/5">
        <h2 class="text-sm font-semibold text-gray-900 dark:text-white">{{this.program_date}}</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 text-sm dark:divide-white/10">
          <thead class="bg-gray-50/80 dark:bg-white/5">
            <tr>
              <th scope="col" class="whitespace-nowrap px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Time</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Activity</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Location</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Guests</th>
              <th scope="col" class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Site lead</th>
              <th scope="col" class="relative px-3 py-2 text-right text-xs font-semibold text-gray-600 dark:text-gray-400"><span class="sr-only">Actions</span></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-white/5">
            {{#each this.rows}}
            <tr class="hover:bg-gray-50/80 dark:hover:bg-white/5">
              <td class="whitespace-nowrap px-3 py-2.5 font-medium tabular-nums text-gray-900 dark:text-white">
                {{this.starts_at}}{{#if this.ends_at}}<span class="font-normal text-gray-500 dark:text-gray-400"> — {{this.ends_at}}</span>{{/if}}
              </td>
              <td class="px-3 py-2.5">
                <a href="/admin/festival/activities/{{this.activity_id}}/edit?returnTo=program" class="font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">{{this.activity_title}}</a>
              </td>
              <td class="px-3 py-2.5">
                <a href="/admin/festival/locations/{{this.location_id}}/edit" class="text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">{{this.location_name}}</a>
              </td>
              <td class="px-3 py-2.5 text-gray-700 dark:text-gray-300">
                {{#if this.presenters.length}}
                <ul class="max-w-xs space-y-0.5">
                  {{#each this.presenters}}
                  <li><a href="/admin/festival/guests/{{this.guest_id}}/edit" class="text-indigo-600 hover:underline dark:text-indigo-400">{{this.profile_name}}</a></li>
                  {{/each}}
                </ul>
                {{else}}<span class="text-gray-400">—</span>{{/if}}
              </td>
              <td class="px-3 py-2.5 text-gray-700 dark:text-gray-300">
                {{#if this.coordinator_name}}
                <a href="/admin/festival/locations/{{this.location_id}}/edit" class="text-indigo-600 hover:underline dark:text-indigo-400">{{this.coordinator_name}}</a>
                {{else}}<span class="text-gray-400">—</span>{{/if}}
              </td>
              <td class="whitespace-nowrap px-3 py-2.5 text-right">
                <a href="/admin/festival/program/{{this.program_id}}/edit" class="text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">Edit</a>
                <form method="POST" action="/admin/festival/program/{{this.program_id}}/delete" class="ml-3 inline">
                  <button type="submit" class="text-sm text-red-600 hover:text-red-800 dark:text-red-400" onclick="return confirm('Delete this program entry?')">Delete</button>
                </form>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
    {{/each}}
  </div>

  {{> pagination page=page totalPages=totalPages extraQuery=""}}
  {{/unless}}
  {{/unless}}
</div>

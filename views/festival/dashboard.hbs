<div class="mx-auto max-w-6xl">
  <div class="flex flex-wrap items-center gap-3">
    {{> festival_edition_switcher allEditions=allEditions edition=edition festivalNavEditionId=festivalNavEditionId switchEditionReturnTo=switchEditionReturnTo }}
    {{#if edition}}
    <a href="/admin/festival/editions/{{edition.id}}/edit" class="rounded-md bg-white px-3 py-1.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-gray-300 hover:bg-gray-50 dark:bg-white/10 dark:text-white dark:ring-white/20 dark:hover:bg-white/15">Edit edition</a>
    {{/if}}
    <a href="/admin/festival/editions/new" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">New edition</a>
  </div>

  {{#unless edition}}
  <div class="mt-10 rounded-xl border border-dashed border-gray-300 bg-gray-50/50 p-10 text-center dark:border-white/20 dark:bg-white/5">
    <p class="text-sm font-medium text-gray-900 dark:text-white">No festival editions yet</p>
    <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Create an edition to manage program, locations, and tickets.</p>
    <p class="mt-6">
      <a href="/admin/festival/editions/new" class="inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Create first edition</a>
    </p>
  </div>
  {{else}}

  <header class="mt-6 overflow-hidden rounded-2xl p-6 shadow-lg ring-1 ring-black/10 sm:p-8"
    style="background-color: {{#if edition.main_color}}{{edition.main_color}}{{else}}#312e81{{/if}}">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <h1 class="text-2xl font-bold tracking-tight"
          style="color: {{#if edition.secondary_color}}{{edition.secondary_color}}{{else}}#c4b5fd{{/if}}">
          {{#if edition.title}}{{edition.title}}{{else}}Festival {{edition.year}}{{/if}}
          <span class="ml-2 text-base font-normal opacity-80">({{ticketCount}} tickets)</span>
        </h1>
        {{#if edition.theme}}<p class="mt-2 text-sm text-white/80">{{edition.theme}}</p>{{/if}}
      </div>
      <a href="/admin/festival/editions/{{edition.id}}/tickets" class="shrink-0 text-sm font-semibold text-white/90 underline decoration-white/40 hover:text-white hover:decoration-white">View tickets →</a>
    </div>
    {{#if edition.short_description}}
    <p class="mt-5 max-w-3xl text-sm leading-relaxed text-white/90">{{edition.short_description}}</p>
    {{/if}}
    {{#if edition.long_description}}
    <div class="mt-3 max-w-3xl text-sm leading-relaxed text-white/80">
      {{{markdown edition.long_description}}}
    </div>
    {{/if}}
    {{#if edition.blog_tag_name}}
    <p class="mt-4">
      <a href="/admin/blog?tag={{edition.blog_tag_id}}" class="inline-flex items-center gap-1 rounded-full px-3 py-1 text-xs font-bold ring-1 ring-white/20 hover:ring-white/40"
        style="color: {{#if edition.accent_color}}{{edition.accent_color}}{{else}}#f0abfc{{/if}}">
        #{{edition.blog_tag_name}}
      </a>
    </p>
    {{/if}}
  </header>

  {{!-- Program table --}}
  <section class="mt-10">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Program</h2>
      <a href="/admin/festival/editions/{{edition.id}}/program/new" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-500">New entry</a>
    </div>

    {{#unless scheduleByDay.length}}
    <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">No program entries yet.</p>
    {{else}}
    <div class="mt-4 space-y-6">
      {{#each scheduleByDay}}
      <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm dark:border-white/10 dark:bg-gray-950/40">
        <div class="border-b border-gray-100 bg-gray-50 px-4 py-2.5 dark:border-white/10 dark:bg-white/5">
          <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{{this.program_date}}</h3>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200 text-sm dark:divide-white/10">
            <thead class="bg-gray-50/80 dark:bg-white/5">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Time</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Activity</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Location</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Guests</th>
                <th class="px-3 py-2 text-left text-xs font-semibold text-gray-600 dark:text-gray-400">Site lead</th>
                <th class="relative px-3 py-2"><span class="sr-only">Edit</span></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-white/5">
              {{#each this.rows}}
              <tr class="hover:bg-gray-50/80 dark:hover:bg-white/5">
                <td class="whitespace-nowrap px-3 py-2.5 font-medium tabular-nums text-gray-900 dark:text-white">
                  {{this.starts_at}}{{#if this.ends_at}}<span class="font-normal text-gray-500 dark:text-gray-400"> — {{this.ends_at}}</span>{{/if}}
                </td>
                <td class="px-3 py-2.5 text-gray-900 dark:text-white">{{this.activity_title}}</td>
                <td class="px-3 py-2.5">
                  <a href="/admin/festival/locations/{{this.location_id}}/edit" class="text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">{{this.location_name}}</a>
                </td>
                <td class="px-3 py-2.5 text-gray-700 dark:text-gray-300">
                  {{#if this.presenters.length}}
                  <ul class="space-y-0.5">
                    {{#each this.presenters}}
                    <li><a href="/admin/festival/guests/{{this.guest_id}}/edit" class="text-indigo-600 hover:underline dark:text-indigo-400">{{this.profile_name}}</a></li>
                    {{/each}}
                  </ul>
                  {{else}}<span class="text-gray-400">—</span>{{/if}}
                </td>
                <td class="px-3 py-2.5 text-gray-700 dark:text-gray-300">
                  {{#if this.coordinator_name}}{{this.coordinator_name}}{{else}}<span class="text-gray-400">—</span>{{/if}}
                </td>
                <td class="whitespace-nowrap px-3 py-2.5 text-right">
                  <a href="/admin/festival/program/{{this.program_id}}/edit" class="text-sm font-medium text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">Edit</a>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
      {{/each}}
    </div>
    {{/unless}}
  </section>

  {{!-- Sponsors --}}
  <section class="mt-10">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-base font-semibold text-gray-900 dark:text-white">Sponsors</h2>
      <a href="/admin/festival/editions/{{edition.id}}/sponsors/new" class="text-sm font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400">Add sponsor</a>
    </div>
    {{#unless sponsors.length}}
    <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">No sponsors yet.</p>
    {{else}}
    <div class="mt-4 flex flex-wrap items-center gap-6">
      {{#each sponsors}}
      <a href="/admin/festival/sponsors/{{this.id}}/edit" class="group flex items-center gap-3 rounded-lg border border-gray-200 bg-white px-4 py-3 shadow-sm transition hover:border-indigo-300 hover:shadow dark:border-white/10 dark:bg-gray-950/40 dark:hover:border-indigo-500/40" title="{{this.sponsorship_type}} / {{this.sponsorship_level}}">
        {{#if this.logo_file}}
        <img src="/uploads/sponsors/{{this.logo_file}}" alt="{{this.name}}" class="h-8 w-auto object-contain" />
        {{else}}
        <span class="flex h-8 w-8 items-center justify-center rounded bg-gray-100 text-xs font-bold text-gray-500 dark:bg-white/10 dark:text-gray-400">{{this.name.[0]}}</span>
        {{/if}}
        <span class="text-sm font-medium text-gray-900 group-hover:text-indigo-600 dark:text-white dark:group-hover:text-indigo-400">{{this.name}}</span>
      </a>
      {{/each}}
    </div>
    {{/unless}}
  </section>
  {{/unless}}
</div>

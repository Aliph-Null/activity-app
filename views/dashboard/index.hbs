<div>
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">Dashboard</h1>
  <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">Overview of AI3 administration data.</p>
</div>

<dl class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
  <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 dark:bg-white/5 dark:ring-1 dark:ring-white/10">
    <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">Total Profiles</dt>
    <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">{{stats.totalProfiles}}</dd>
  </div>

  <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 dark:bg-white/5 dark:ring-1 dark:ring-white/10">
    <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">Total Members</dt>
    <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">{{stats.totalMembers}}</dd>
    <dd class="mt-2 flex flex-wrap gap-3 text-sm">
      <span class="inline-flex items-center rounded-md bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-800 ring-1 ring-yellow-600/20 ring-inset dark:bg-yellow-400/10 dark:text-yellow-500 dark:ring-yellow-400/20">{{stats.aspiringMembers}} aspiring</span>
      <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-green-600/20 ring-inset dark:bg-green-500/10 dark:text-green-400 dark:ring-green-500/20">{{stats.fullMembers}} full</span>
    </dd>
  </div>

  <div class="overflow-hidden rounded-lg bg-white px-4 py-5 shadow sm:p-6 dark:bg-white/5 dark:ring-1 dark:ring-white/10">
    <dt class="truncate text-sm font-medium text-gray-500 dark:text-gray-400">Upcoming Meetups</dt>
    <dd class="mt-1 text-3xl font-semibold tracking-tight text-gray-900 dark:text-white">{{stats.upcomingMeetups}}</dd>
    {{#if stats.nextMeetup}}
    <dd class="mt-2 text-sm text-gray-500 dark:text-gray-400">Next: {{stats.nextMeetup}}</dd>
    {{else}}
    <dd class="mt-2 text-sm text-gray-500 dark:text-gray-400">No upcoming meetups</dd>
    {{/if}}
  </div>
</dl>

<div class="mt-12 grid grid-cols-1 gap-8 lg:grid-cols-2">
  <div>
    <h2 class="text-sm font-semibold text-gray-900 dark:text-white">Quick Actions</h2>
    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
      <a href="/admin/profiles/new" class="rounded-lg border border-gray-200 p-4 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-white/10 dark:text-gray-300 dark:hover:bg-white/5">
        <span class="block text-indigo-600 dark:text-indigo-400">+ New Profile</span>
        <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">Add a person to the system</span>
      </a>
      <a href="/admin/members/new" class="rounded-lg border border-gray-200 p-4 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-white/10 dark:text-gray-300 dark:hover:bg-white/5">
        <span class="block text-indigo-600 dark:text-indigo-400">+ New Member</span>
        <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">Register an association member</span>
      </a>
      <a href="/admin/meetups/new" class="rounded-lg border border-gray-200 p-4 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-white/10 dark:text-gray-300 dark:hover:bg-white/5">
        <span class="block text-indigo-600 dark:text-indigo-400">+ New Meetup</span>
        <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">Schedule a weekly meetup</span>
      </a>
      <a href="/admin/users/new" class="rounded-lg border border-gray-200 p-4 text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-white/10 dark:text-gray-300 dark:hover:bg-white/5">
        <span class="block text-indigo-600 dark:text-indigo-400">+ New User</span>
        <span class="mt-1 block text-xs text-gray-500 dark:text-gray-400">Create a platform account</span>
      </a>
    </div>
  </div>
</div>

<div class="mx-auto max-w-2xl">
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isEdit}}Edit Member{{else}}New Member{{/if}}</h1>

  <form method="POST" action="{{#if isEdit}}/admin/members/{{member.id}}{{else}}/admin/members{{/if}}" class="mt-8 space-y-6">
    {{#unless isEdit}}
    <div>
      <label for="profile_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Profile <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <select name="profile_id" id="profile_id" required
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
          <option value="">Select a profile...</option>
          {{#each profiles}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    {{else}}
    <div>
      <label class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Profile</label>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{{member.profile_name}}</p>
    </div>
    {{/unless}}

    <div>
      <label for="joined_at" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Joined At <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <input type="date" name="joined_at" id="joined_at" required value="{{member.joined_at}}"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
      </div>
    </div>

    <fieldset>
      <legend class="text-sm/6 font-medium text-gray-900 dark:text-gray-200">Member Category <span class="text-red-500">*</span></legend>
      <div class="mt-3 space-y-3">
        <div class="flex items-center gap-x-3">
          <input id="cat_aspiring" name="member_category" type="radio" value="aspiring" required
            {{#if (eq member.member_category 'aspiring')}}checked{{/if}}
            {{#unless isEdit}}checked{{/unless}}
            onchange="document.getElementById('full_kind_section').style.display='none'"
            class="size-4 border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="cat_aspiring" class="text-sm/6 text-gray-900 dark:text-gray-300">Aspiring</label>
        </div>
        <div class="flex items-center gap-x-3">
          <input id="cat_full" name="member_category" type="radio" value="full"
            {{#if (eq member.member_category 'full')}}checked{{/if}}
            onchange="document.getElementById('full_kind_section').style.display='block'"
            class="size-4 border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="cat_full" class="text-sm/6 text-gray-900 dark:text-gray-300">Full Member</label>
        </div>
      </div>
    </fieldset>

    <div id="full_kind_section" style="{{#if (eq member.member_category 'full')}}display:block{{else}}display:none{{/if}}">
      <label for="full_member_kind" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Full Member Kind</label>
      <div class="mt-2">
        <select name="full_member_kind" id="full_member_kind"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
          <option value="regular" {{#if (eq member.full_member_kind 'regular')}}selected{{/if}}>Regular</option>
          <option value="founder" {{#if (eq member.full_member_kind 'founder')}}selected{{/if}}>Founder</option>
          <option value="honorary" {{#if (eq member.full_member_kind 'honorary')}}selected{{/if}}>Honorary</option>
        </select>
      </div>
    </div>

    <div class="flex items-center gap-x-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">
        {{#if isEdit}}Update{{else}}Create{{/if}}
      </button>
      <a href="/admin/members" class="text-sm/6 font-semibold text-gray-900 dark:text-gray-300">Cancel</a>
    </div>
  </form>
</div>

<div class="mx-auto max-w-2xl">
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isEdit}}Edit User{{else}}New User{{/if}}</h1>

  <form method="POST" action="{{#if isEdit}}/admin/users/{{editUser.id}}{{else}}/admin/users{{/if}}" class="mt-8 space-y-6">
    {{#unless isEdit}}
    <div>
      <label for="profile_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Profile <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <select name="profile_id" id="profile_id" required
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
          <option value="">Select a profile...</option>
          {{#each profiles}}
          <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
    </div>
    {{/unless}}

    <div>
      <label for="username" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Username <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <input type="text" name="username" id="username" required value="{{editUser.username}}"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
      </div>
    </div>

    <div>
      <label for="password" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Password {{#unless isEdit}}<span class="text-red-500">*</span>{{/unless}}</label>
      {{#if isEdit}}<p class="text-xs text-gray-500 dark:text-gray-400">Leave blank to keep current password.</p>{{/if}}
      <div class="mt-2">
        <input type="password" name="password" id="password" {{#unless isEdit}}required{{/unless}}
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
      </div>
    </div>

    <fieldset>
      <legend class="text-sm/6 font-medium text-gray-900 dark:text-gray-200">Roles</legend>
      <div class="mt-2 space-y-2">
        {{#each roles}}
        <div class="flex items-center gap-x-3">
          <input id="role_{{this.id}}" name="role_ids" value="{{this.id}}" type="checkbox"
            {{#if (includes ../editUser.roles this.name)}}checked{{/if}}
            class="size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="role_{{this.id}}" class="text-sm/6 text-gray-900 dark:text-gray-300">{{this.name}}</label>
        </div>
        {{/each}}
      </div>
    </fieldset>

    <div class="flex items-center gap-x-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">
        {{#if isEdit}}Update{{else}}Create{{/if}}
      </button>
      <a href="/admin/users" class="text-sm/6 font-semibold text-gray-900 dark:text-gray-300">Cancel</a>
    </div>
  </form>
</div>

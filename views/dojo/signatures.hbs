<div class="mx-auto max-w-3xl">
  <div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
      <h1 class="text-base font-semibold text-gray-900 dark:text-white">Signatures – {{entity.profile_name}}</h1>
      <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">Manage signatures for this {{entityType}}.</p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
      <a href="/admin/dojo/{{entityType}}s" class="text-sm font-semibold text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white">&larr; Back to {{entityType}}s</a>
    </div>
  </div>

  <form method="POST" action="/admin/dojo/{{entityType}}s/{{entityId}}/signatures" class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-end">
    <div>
      <label for="document_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Document</label>
      <select name="document_id" id="document_id" required
        class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:w-48 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
        <option value="">Select document...</option>
        {{#each documents}}
        <option value="{{this.id}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div>
      <label for="signed_at" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Signed At</label>
      <input type="date" name="signed_at" id="signed_at" required
        class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:w-40 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
    </div>
    <button type="submit" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-500">Add signature</button>
  </form>

  <div class="mt-8 flow-root">
    <table class="min-w-full divide-y divide-gray-300 dark:divide-white/10">
      <thead>
        <tr>
          <th class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Document</th>
          <th class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Signed</th>
          <th class="relative py-3.5 pr-4 pl-3 sm:pr-0"><span class="sr-only">Actions</span></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200 dark:divide-white/5">
        {{#each signatures}}
        <tr>
          <td class="whitespace-nowrap py-4 pr-3 pl-4 text-sm font-medium text-gray-900 dark:text-white sm:pl-0">{{this.document_name}}</td>
          <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.signed_at}}</td>
          <td class="relative whitespace-nowrap py-4 pr-4 pl-3 text-right text-sm font-medium sm:pr-0">
            <form method="POST" action="/admin/dojo/{{../entityType}}s/{{../entityId}}/signatures/{{this.id}}/delete" class="inline">
              <button type="submit" onclick="return confirm('Are you sure?')" class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300">Delete</button>
            </form>
          </td>
        </tr>
        {{/each}}
        {{#unless signatures.length}}
        <tr>
          <td colspan="3" class="py-8 text-center text-sm text-gray-500 dark:text-gray-400">No signatures yet.</td>
        </tr>
        {{/unless}}
      </tbody>
    </table>
  </div>
</div>

<div class="mx-auto max-w-2xl">
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isEdit}}Edit Session{{else}}New Session{{/if}}</h1>

  <form method="POST" action="{{#if isEdit}}/admin/dojo/sessions/{{session.id}}{{else}}/admin/dojo/sessions{{/if}}" class="mt-8 space-y-6">
    <div>
      <label for="starts_at" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Date &amp; Time <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <input type="datetime-local" name="starts_at" id="starts_at" required value="{{session.starts_at}}"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
      </div>
    </div>

    <div>
      <label for="location" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Location <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <input type="text" name="location" id="location" required value="{{session.location}}"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
      </div>
    </div>

    <div>
      <label for="theme" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Theme</label>
      <div class="mt-2">
        <input type="text" name="theme" id="theme" value="{{session.theme}}"
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
      </div>
    </div>

    <div>
      <label for="mentor_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Mentor <span class="text-red-500">*</span></label>
      <div class="mt-2">
        <select name="mentor_id" id="mentor_id" required
          class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
          <option value="">Select a mentor...</option>
          {{#each mentors}}
          <option value="{{this.id}}" {{#if (eq this.id ../session.mentor_id)}}selected{{/if}}>{{this.profile_name}}</option>
          {{/each}}
        </select>
      </div>
    </div>

    <div class="flex items-center gap-x-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">
        {{#if isEdit}}Update{{else}}Create{{/if}}
      </button>
      <a href="/admin/dojo/sessions" class="text-sm/6 font-semibold text-gray-900 dark:text-gray-300">Cancel</a>
    </div>
  </form>
</div>

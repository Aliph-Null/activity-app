{{> dojo_tabs tab=tab }}
<div class="sm:flex sm:items-center">
  <div class="sm:flex-auto">
    <h1 class="text-base font-semibold text-gray-900 dark:text-white">Sessions</h1>
    <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">Dojo sessions.</p>
  </div>
  <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
    <a href="/admin/dojo/sessions/new" class="block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">Add session</a>
  </div>
</div>

<form method="GET" action="/admin/dojo/sessions" class="mt-6 flex flex-col gap-3 rounded-lg border border-gray-200 p-4 dark:border-white/10 sm:flex-row sm:flex-wrap sm:items-end">
  <div>
    <label for="date_from" class="block text-xs font-medium text-gray-500 dark:text-gray-400">From (date)</label>
    <input type="date" name="date_from" id="date_from" value="{{date_from}}"
      class="mt-1 block rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:[color-scheme:dark]" />
  </div>
  <div>
    <label for="date_to" class="block text-xs font-medium text-gray-500 dark:text-gray-400">To (date)</label>
    <input type="date" name="date_to" id="date_to" value="{{date_to}}"
      class="mt-1 block rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:[color-scheme:dark]" />
  </div>
  <div class="min-w-[12rem] flex-1">
    <label for="theme" class="block text-xs font-medium text-gray-500 dark:text-gray-400">Theme contains</label>
    <input type="search" name="theme" id="theme" value="{{theme}}" placeholder="e.g. Scratch"
      class="mt-1 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10" />
  </div>
  <div class="flex gap-2">
    <button type="submit" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-500">Filter</button>
    <button type="button" class="rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-semibold text-gray-900 hover:bg-gray-50 dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10"
      onclick="window.location.href='/admin/dojo/sessions'">Clear</button>
  </div>
</form>

<div class="mt-8 flow-root">
  <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
    <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
      <table class="min-w-full divide-y divide-gray-300 dark:divide-white/10">
        <thead>
          <tr>
            <th scope="col" class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Date/Time</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Location</th>
            <th scope="col" class="hidden px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white sm:table-cell">Theme</th>
            <th scope="col" class="hidden px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white md:table-cell">Mentor</th>
            <th scope="col" class="hidden px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white lg:table-cell">Created</th>
            <th scope="col" class="relative py-3.5 pr-4 pl-3 sm:pr-0"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-white/5">
          {{#each items}}
          <tr>
            <td class="whitespace-nowrap py-4 pr-3 pl-4 text-sm font-medium text-gray-900 dark:text-white sm:pl-0">{{this.starts_at}}</td>
            <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400">{{this.location}}</td>
            <td class="hidden whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400 sm:table-cell">{{this.theme}}</td>
            <td class="hidden whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400 md:table-cell">{{this.mentor_name}}</td>
            <td class="hidden whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400 lg:table-cell">{{this.created_at}}</td>
            <td class="relative whitespace-nowrap py-4 pr-4 pl-3 text-right text-sm font-medium sm:pr-0">
              <a href="/admin/dojo/sessions/{{this.id}}/edit" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300">Edit</a>
              <form method="POST" action="/admin/dojo/sessions/{{this.id}}/delete" class="inline ml-3">
                <button type="submit" onclick="return confirm('Are you sure?')" class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300">Delete</button>
              </form>
            </td>
          </tr>
          {{/each}}
          {{#unless items.length}}
          <tr>
            <td colspan="6" class="py-8 text-center text-sm text-gray-500 dark:text-gray-400">No sessions found.</td>
          </tr>
          {{/unless}}
        </tbody>
      </table>
    </div>
  </div>
</div>

{{> pagination page=page totalPages=totalPages extraQuery=extraQuery }}

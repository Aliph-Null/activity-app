{{> dojo_tabs tab=tab }}
<div class="sm:flex sm:items-center">
  <div class="sm:flex-auto">
    <h1 class="text-base font-semibold text-gray-900 dark:text-white">Agreement Signatures</h1>
    <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">Overview of which mentors and tutors have signed each agreement document.</p>
  </div>
</div>

{{#unless documents.length}}
<div class="mt-8 rounded-md bg-yellow-50 p-4 dark:bg-yellow-400/10">
  <p class="text-sm text-yellow-800 dark:text-yellow-200">No agreement documents defined yet. <a href="/admin/dojo/documents" class="font-medium underline">Create documents first.</a></p>
</div>
{{/unless}}

{{#if documents.length}}
<h2 class="mt-10 text-sm font-semibold text-gray-900 dark:text-white">Mentors</h2>
{{#if mentorRows.length}}
<div class="mt-4 flow-root">
  <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
    <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
      <table class="min-w-full divide-y divide-gray-300 dark:divide-white/10">
        <thead>
          <tr>
            <th scope="col" class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Mentor</th>
            {{#each documents}}
            <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900 dark:text-white">
              {{#if this.file_path}}<a href="/admin/dojo/documents/{{this.id}}/download" target="_blank" class="underline decoration-dotted hover:decoration-solid" title="Download {{this.original_filename}}">{{this.name}}</a>{{else}}{{this.name}}{{/if}}
            </th>
            {{/each}}
            <th scope="col" class="relative py-3.5 pr-4 pl-3 sm:pr-0"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-white/5">
          {{#each mentorRows}}
          <tr>
            <td class="whitespace-nowrap py-4 pr-3 pl-4 text-sm font-medium text-gray-900 dark:text-white sm:pl-0">{{this.profile_name}}</td>
            {{#each this.docs}}
            <td class="whitespace-nowrap px-3 py-4 text-center text-sm">
              {{#if this.signed_at}}
                <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-green-600/20 ring-inset dark:bg-green-500/10 dark:text-green-400 dark:ring-green-500/20" title="Signed {{this.signed_at}}">{{this.signed_at}}</span>
              {{else}}
                <span class="inline-flex items-center rounded-md bg-red-50 px-2 py-1 text-xs font-medium text-red-700 ring-1 ring-red-600/10 ring-inset dark:bg-red-400/10 dark:text-red-400 dark:ring-red-400/20">Missing</span>
              {{/if}}
            </td>
            {{/each}}
            <td class="relative whitespace-nowrap py-4 pr-4 pl-3 text-right text-sm font-medium sm:pr-0">
              <a href="/admin/dojo/mentors/{{this.id}}/signatures" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300">Manage</a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>
{{else}}
<p class="mt-4 text-sm text-gray-500 dark:text-gray-400">No mentors registered yet.</p>
{{/if}}

<h2 class="mt-10 text-sm font-semibold text-gray-900 dark:text-white">Tutors</h2>
{{#if tutorRows.length}}
<div class="mt-4 flow-root">
  <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
    <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
      <table class="min-w-full divide-y divide-gray-300 dark:divide-white/10">
        <thead>
          <tr>
            <th scope="col" class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Tutor</th>
            {{#each documents}}
            <th scope="col" class="px-3 py-3.5 text-center text-sm font-semibold text-gray-900 dark:text-white">
              {{#if this.file_path}}<a href="/admin/dojo/documents/{{this.id}}/download" target="_blank" class="underline decoration-dotted hover:decoration-solid" title="Download {{this.original_filename}}">{{this.name}}</a>{{else}}{{this.name}}{{/if}}
            </th>
            {{/each}}
            <th scope="col" class="relative py-3.5 pr-4 pl-3 sm:pr-0"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-white/5">
          {{#each tutorRows}}
          <tr>
            <td class="whitespace-nowrap py-4 pr-3 pl-4 text-sm font-medium text-gray-900 dark:text-white sm:pl-0">{{this.profile_name}}</td>
            {{#each this.docs}}
            <td class="whitespace-nowrap px-3 py-4 text-center text-sm">
              {{#if this.signed_at}}
                <span class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-green-600/20 ring-inset dark:bg-green-500/10 dark:text-green-400 dark:ring-green-500/20" title="Signed {{this.signed_at}}">{{this.signed_at}}</span>
              {{else}}
                <span class="inline-flex items-center rounded-md bg-red-50 px-2 py-1 text-xs font-medium text-red-700 ring-1 ring-red-600/10 ring-inset dark:bg-red-400/10 dark:text-red-400 dark:ring-red-400/20">Missing</span>
              {{/if}}
            </td>
            {{/each}}
            <td class="relative whitespace-nowrap py-4 pr-4 pl-3 text-right text-sm font-medium sm:pr-0">
              <a href="/admin/dojo/tutors/{{this.id}}/signatures" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300">Manage</a>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
</div>
{{else}}
<p class="mt-4 text-sm text-gray-500 dark:text-gray-400">No tutors registered yet.</p>
{{/if}}
{{/if}}

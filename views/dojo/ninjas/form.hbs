{{> dojo_tabs tab=tab }}

<div class="mx-auto max-w-3xl">
  <div class="sm:flex sm:items-start sm:justify-between">
    <div>
      <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isEdit}}Edit ninja &amp; guardian{{else}}Register ninja{{/if}}</h1>
      <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">{{#if isEdit}}Update contact details for the child and guardian, ninja notes, and tutor agreement dates. The ninja–guardian pairing does not change here.{{else}}Create the child and guardian profiles and link them as one ninja registration. You can record tutor agreement signatures in the same step.{{/if}}</p>
    </div>
    <button type="button" class="mt-4 text-sm font-semibold text-indigo-600 hover:text-indigo-500 dark:text-indigo-400 sm:mt-0"
      onclick="window.location.href='/admin/dojo/ninjas'">Back to list</button>
  </div>

  <form method="POST" action="{{#if isEdit}}/admin/dojo/ninjas/{{ninja.id}}{{else}}/admin/dojo/ninjas{{/if}}" id="ninja-wizard-form" class="mt-8 space-y-8">

    {{!-- Child (ninja) profile + notes --}}
    <fieldset class="rounded-lg border border-gray-200 p-4 dark:border-white/10">
      <legend class="px-1 text-sm font-semibold text-gray-900 dark:text-white">1. Ninja (child)</legend>
      <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">Participant profile and dojo-specific notes (allergies, age group, etc.).</p>

      <div class="mt-4 space-y-4">
        <div>
          <label for="ninja_name" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Name <span class="text-red-500">*</span></label>
          <input type="text" name="ninja_name" id="ninja_name" required value="{{ninja.ninjaProfile.name}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500" />
        </div>
        <div>
          <label for="ninja_email" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Email</label>
          <input type="email" name="ninja_email" id="ninja_email" value="{{ninja.ninjaProfile.email}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500" />
        </div>
        <div>
          <label for="ninja_phone" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Phone</label>
          <input type="text" name="ninja_phone" id="ninja_phone" value="{{ninja.ninjaProfile.phone}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500" />
        </div>
        <div>
          <label for="ninja_birth_date" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Birth date</label>
          <input type="date" name="ninja_birth_date" id="ninja_birth_date" value="{{ninja.ninjaProfile.birth_date}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
        </div>
        <div>
          <label for="useful_info" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Ninja notes</label>
          <textarea name="useful_info" id="useful_info" rows="3"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500">{{ninja.useful_info}}</textarea>
        </div>
      </div>
    </fieldset>

    {{!-- Guardian profile (tutor record is 1:1 with this ninja; only contact fields here) --}}
    <fieldset class="rounded-lg border border-gray-200 p-4 dark:border-white/10">
      <legend class="px-1 text-sm font-semibold text-gray-900 dark:text-white">2. Guardian (responsible tutor)</legend>
      <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">Adult responsible for this ninja. Agreement signatures below apply to this person. Manage standalone tutor-only details elsewhere if needed.</p>

      <div class="mt-4 space-y-4">
        <div>
          <label for="tutor_name" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Name <span class="text-red-500">*</span></label>
          <input type="text" name="tutor_name" id="tutor_name" required value="{{ninja.tutorProfile.name}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500" />
        </div>
        <div>
          <label for="tutor_email" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Email</label>
          <input type="email" name="tutor_email" id="tutor_email" value="{{ninja.tutorProfile.email}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500" />
        </div>
        <div>
          <label for="tutor_phone" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Phone</label>
          <input type="text" name="tutor_phone" id="tutor_phone" value="{{ninja.tutorProfile.phone}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500" />
        </div>
        <div>
          <label for="tutor_birth_date" class="block text-sm/6 font-medium text-gray-900 dark:text-white">Birth date</label>
          <input type="date" name="tutor_birth_date" id="tutor_birth_date" value="{{ninja.tutorProfile.birth_date}}"
            class="mt-2 block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
        </div>
      </div>
    </fieldset>

    {{!-- Tutor agreements --}}
    <fieldset class="rounded-lg border border-gray-200 p-4 dark:border-white/10">
      <legend class="px-1 text-sm font-semibold text-gray-900 dark:text-white">3. Tutor agreement signatures</legend>
      <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">Add each agreement the guardian has signed: document and signed date. Saving replaces this guardian’s agreement list for this registration.</p>

      {{#if agreementDocuments.length}}
      <div id="tutor-sig-container" class="mt-4 space-y-3"></div>
      <button type="button" id="tutor-sig-add"
        class="mt-2 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-semibold text-gray-900 shadow-xs hover:bg-gray-50 dark:border-white/10 dark:bg-white/5 dark:text-white dark:hover:bg-white/10">
        Add agreement
      </button>
      <input type="hidden" name="tutor_signatures_json" id="tutor_signatures_json" value="[]" />
      {{else}}
      <p class="mt-4 text-sm text-amber-800 dark:text-amber-200/90">No agreement documents are defined yet. Add files under <a href="/admin/dojo/documents" class="font-medium underline">Documents</a>, then return here.</p>
      {{/if}}
    </fieldset>

    <div class="flex flex-wrap items-center gap-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">
        {{#if isEdit}}Save{{else}}Register ninja{{/if}}
      </button>
      <button type="button" class="text-sm font-semibold text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white"
        onclick="window.location.href='/admin/dojo/ninjas'">Cancel</button>
    </div>
  </form>
</div>

<script>
(function() {
  var DOCS = {{{json agreementDocuments}}};
  var INITIAL_ROWS = {{{json tutorSignatureRows}}};

  function buildTutorSigRow(docId, dateVal) {
    var wrap = document.createElement('div');
    wrap.className = 'tutor-sig-row flex flex-col gap-2 rounded-md border border-gray-200 p-3 sm:flex-row sm:items-end dark:border-white/10';
    var sel = document.createElement('select');
    sel.className = 'block w-full rounded-md bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10 sm:max-w-md';
    var opt0 = document.createElement('option');
    opt0.value = '';
    opt0.textContent = 'Select document…';
    sel.appendChild(opt0);
    for (var i = 0; i < DOCS.length; i++) {
      var d = DOCS[i];
      var o = document.createElement('option');
      o.value = String(d.id);
      o.textContent = d.name;
      if (docId != null && docId !== '' && String(d.id) === String(docId)) o.selected = true;
      sel.appendChild(o);
    }
    var inp = document.createElement('input');
    inp.type = 'date';
    inp.className = 'rounded-md border-0 bg-white px-3 py-1.5 text-sm text-gray-900 outline-1 -outline-offset-1 outline-gray-300 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:[color-scheme:dark] sm:w-40';
    if (dateVal) inp.value = dateVal;
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'shrink-0 text-sm font-semibold text-red-600 hover:text-red-800 dark:text-red-400 dark:hover:text-red-300';
    btn.textContent = 'Remove';
    btn.addEventListener('click', function() { wrap.remove(); });
    var inner = document.createElement('div');
    inner.className = 'flex flex-1 flex-col gap-1 sm:flex-row sm:items-end sm:gap-4';
    var d1 = document.createElement('div');
    d1.className = 'flex-1';
    var l1 = document.createElement('label');
    l1.className = 'block text-xs font-medium text-gray-500 dark:text-gray-400';
    l1.textContent = 'Document';
    d1.appendChild(l1);
    d1.appendChild(sel);
    var d2 = document.createElement('div');
    var l2 = document.createElement('label');
    l2.className = 'block text-xs font-medium text-gray-500 dark:text-gray-400';
    l2.textContent = 'Signed on';
    d2.appendChild(l2);
    d2.appendChild(inp);
    inner.appendChild(d1);
    inner.appendChild(d2);
    wrap.appendChild(inner);
    wrap.appendChild(btn);
    return wrap;
  }

  var form = document.getElementById('ninja-wizard-form');
  var container = document.getElementById('tutor-sig-container');
  var addBtn = document.getElementById('tutor-sig-add');
  var hiddenJson = document.getElementById('tutor_signatures_json');

  if (container && addBtn && hiddenJson && form) {
    addBtn.addEventListener('click', function() {
      container.appendChild(buildTutorSigRow('', ''));
    });
    if (INITIAL_ROWS && INITIAL_ROWS.length) {
      for (var j = 0; j < INITIAL_ROWS.length; j++) {
        var r = INITIAL_ROWS[j];
        container.appendChild(buildTutorSigRow(r.document_id, r.signed_at || ''));
      }
    }
    form.addEventListener('submit', function() {
      var out = [];
      var rows = container.querySelectorAll('.tutor-sig-row');
      for (var k = 0; k < rows.length; k++) {
        var row = rows[k];
        var s = row.querySelector('select');
        var inp = row.querySelector('input[type="date"]');
        var did = parseInt(s && s.value ? s.value : '', 10);
        var dt = inp && inp.value ? inp.value.trim() : '';
        if (Number.isFinite(did) && dt.length >= 8) {
          out.push({ document_id: did, signed_at: dt });
        }
      }
      hiddenJson.value = JSON.stringify(out);
    });
  }
})();
</script>

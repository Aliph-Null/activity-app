<div class="sm:flex sm:items-center">
  <div class="sm:flex-auto">
    <h1 class="text-base font-semibold text-gray-900 dark:text-white">Meetups</h1>
    <p class="mt-2 text-sm text-gray-700 dark:text-gray-400">Weekly meetups with workshops or anti-workshops.</p>
  </div>
  <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
    <a href="/admin/meetups/new" class="block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">Add meetup</a>
  </div>
</div>

<div class="mt-8 flow-root">
  <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
    <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
      <table class="min-w-full divide-y divide-gray-300 dark:divide-white/10">
        <thead>
          <tr>
            <th scope="col" class="py-3.5 pr-3 pl-4 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-0">Date &amp; Time</th>
            <th scope="col" class="hidden px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white sm:table-cell">Location</th>
            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Type</th>
            <th scope="col" class="hidden px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white md:table-cell">Details</th>
            <th scope="col" class="relative py-3.5 pr-4 pl-3 sm:pr-0"><span class="sr-only">Actions</span></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-white/5">
          {{#each items}}
          <tr>
            <td class="whitespace-nowrap py-4 pr-3 pl-4 text-sm font-medium text-gray-900 dark:text-white sm:pl-0">
              {{this.starts_at}}
              <dl class="font-normal sm:hidden">
                <dd class="mt-1 truncate text-gray-500 dark:text-gray-400">{{this.location}}</dd>
              </dl>
            </td>
            <td class="hidden whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-400 sm:table-cell">{{this.location}}</td>
            <td class="whitespace-nowrap px-3 py-4 text-sm">
              {{#if (eq this.meetup_type 'workshop')}}
              <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 ring-1 ring-indigo-700/10 ring-inset dark:bg-indigo-400/10 dark:text-indigo-400 dark:ring-indigo-400/20">Workshop</span>
              {{else if (eq this.meetup_type 'anti_workshop')}}
              <span class="inline-flex items-center rounded-md bg-orange-50 px-2 py-1 text-xs font-medium text-orange-700 ring-1 ring-orange-600/10 ring-inset dark:bg-orange-400/10 dark:text-orange-400 dark:ring-orange-400/20">Anti-Workshop</span>
              {{else}}
              <span class="text-gray-400">-</span>
              {{/if}}
            </td>
            <td class="hidden px-3 py-4 text-sm text-gray-500 dark:text-gray-400 max-w-xs truncate md:table-cell">
              {{#if (eq this.meetup_type 'workshop')}}
                <strong class="dark:text-gray-300">{{this.workshop_title}}</strong> ({{this.workshop_theme}}) &mdash; {{this.presenter_name}}
              {{else if (eq this.meetup_type 'anti_workshop')}}
                {{this.anti_workshop_agenda}}
              {{/if}}
            </td>
            <td class="relative whitespace-nowrap py-4 pr-4 pl-3 text-right text-sm font-medium sm:pr-0">
              <a href="/admin/meetups/{{this.id}}/edit" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300">Edit</a>
              <form method="POST" action="/admin/meetups/{{this.id}}/delete" class="inline ml-3">
                <button type="submit" class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300" onclick="return confirm('Delete this meetup?')">Delete</button>
              </form>
            </td>
          </tr>
          {{/each}}
          {{#unless items.length}}
          <tr>
            <td colspan="5" class="py-8 text-center text-sm text-gray-500 dark:text-gray-400">No meetups found.</td>
          </tr>
          {{/unless}}
        </tbody>
      </table>
    </div>
  </div>
</div>

{{> pagination page=page totalPages=totalPages }}

<div class="mx-auto max-w-2xl">
  <h1 class="text-base font-semibold text-gray-900 dark:text-white">{{#if isEdit}}Edit Meetup{{else}}New Meetup{{/if}}</h1>

  <form method="POST" action="{{#if isEdit}}/admin/meetups/{{meetup.id}}{{else}}/admin/meetups{{/if}}" class="mt-8 space-y-6">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div>
        <label for="starts_at" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Date &amp; Time <span class="text-red-500">*</span></label>
        <div class="mt-2">
          <input type="datetime-local" name="starts_at" id="starts_at" required value="{{meetup.starts_at}}"
            class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500 dark:[color-scheme:dark]" />
        </div>
      </div>
      <div>
        <label for="location" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Location <span class="text-red-500">*</span></label>
        <div class="mt-2">
          <input type="text" name="location" id="location" required value="{{meetup.location}}"
            class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
        </div>
      </div>
    </div>

    <fieldset>
      <legend class="text-sm/6 font-medium text-gray-900 dark:text-gray-200">Meetup Type <span class="text-red-500">*</span></legend>
      <div class="mt-3 space-y-3">
        <div class="flex items-center gap-x-3">
          <input id="type_workshop" name="meetup_type" type="radio" value="workshop" required
            {{#if (eq meetup.meetup_type 'workshop')}}checked{{/if}}
            {{#unless isEdit}}checked{{/unless}}
            onchange="document.getElementById('workshop_fields').style.display='block'; document.getElementById('anti_workshop_fields').style.display='none'"
            class="size-4 border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="type_workshop" class="text-sm/6 text-gray-900 dark:text-gray-300">Workshop</label>
        </div>
        <div class="flex items-center gap-x-3">
          <input id="type_anti" name="meetup_type" type="radio" value="anti_workshop"
            {{#if (eq meetup.meetup_type 'anti_workshop')}}checked{{/if}}
            onchange="document.getElementById('workshop_fields').style.display='none'; document.getElementById('anti_workshop_fields').style.display='block'"
            class="size-4 border-gray-300 text-indigo-600 focus:ring-indigo-600 dark:border-white/10 dark:bg-white/5" />
          <label for="type_anti" class="text-sm/6 text-gray-900 dark:text-gray-300">Anti-Workshop</label>
        </div>
      </div>
    </fieldset>

    <div id="workshop_fields" style="{{#if (eq meetup.meetup_type 'anti_workshop')}}display:none{{else}}display:block{{/if}}">
      <div class="space-y-6">
        <div>
          <label for="workshop_title" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Workshop Title</label>
          <div class="mt-2">
            <input type="text" name="workshop_title" id="workshop_title" value="{{meetup.workshop_title}}"
              class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" />
          </div>
        </div>
        <div>
          <label for="workshop_theme" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Theme</label>
          <div class="mt-2">
            <select name="workshop_theme" id="workshop_theme"
              class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
              <option value="demo_your_stack" {{#if (eq meetup.workshop_theme 'demo_your_stack')}}selected{{/if}}>Demo Your Stack</option>
              <option value="fup_nights" {{#if (eq meetup.workshop_theme 'fup_nights')}}selected{{/if}}>FUP Nights</option>
              <option value="meet_the_business" {{#if (eq meetup.workshop_theme 'meet_the_business')}}selected{{/if}}>Meet the Business</option>
            </select>
          </div>
        </div>
        <div>
          <label for="presenter_id" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Presenter</label>
          <div class="mt-2">
            <select name="presenter_id" id="presenter_id"
              class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:focus:outline-indigo-500">
              <option value="">Select presenter...</option>
              {{#each profiles}}
              <option value="{{this.id}}" {{#if (eq this.id ../meetup.presenter_id)}}selected{{/if}}>{{this.name}}</option>
              {{/each}}
            </select>
          </div>
        </div>
      </div>
    </div>

    <div id="anti_workshop_fields" style="{{#if (eq meetup.meetup_type 'anti_workshop')}}display:block{{else}}display:none{{/if}}">
      <div>
        <label for="agenda" class="block text-sm/6 font-medium text-gray-900 dark:text-gray-200">Agenda</label>
        <div class="mt-2">
          <textarea name="agenda" id="agenda" rows="4"
            class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500">{{meetup.anti_workshop_agenda}}</textarea>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-x-4">
      <button type="submit" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500">
        {{#if isEdit}}Update{{else}}Create{{/if}}
      </button>
      <a href="/admin/meetups" class="text-sm/6 font-semibold text-gray-900 dark:text-gray-300">Cancel</a>
    </div>
  </form>
</div>
